# Copy to .env before docker compose up.
# Never commit real secrets.
NVIDIA_API_KEY=nvapi-REPLACE_ME
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_VLM_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
NEMOTRON_TIMEOUT=90
NEMOTRON_MAX_TOKENS=1800
RAG_TOP_K=5
ENABLE_DRUG_RANKING=0
NCBI_EMAIL=your_email@example.com
NCBI_TOOL=pediatric_neuro_oncology_agent
